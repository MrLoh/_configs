	},
	{
		"key": "cmd+j",
		"command": "-workbench.action.togglePanel",
		"when": "!isAuxiliaryWindowFocusedContext"
	},
	{
		"key": "cmd+\\",
		"command": "workbench.action.toggleSidebarVisibility",
		"when": "!isAuxiliaryWindowFocusedContext"
	},
	{
		"key": "cmd+b",
		"command": "-workbench.action.toggleSidebarVisibility",
		"when": "!isAuxiliaryWindowFocusedContext"
	},
	{
		"key": "cmd+l",
		"command": "composer.sendToAgent",
		"when": "editorHasPromptBar && editorPromptBarFocused"
	},
	{
		"key": "cmd+l",
		"command": "-composer.sendToAgent",
		"when": "editorHasPromptBar && editorPromptBarFocused"
	},
	{
		"key": "cmd+d",
		"command": "-editor.action.addSelectionToNextFindMatch",
		"when": "editorFocus"
	},
	{
		"key": "cmd+d",
		"command": "-notebook.addFindMatchToSelection",
		"when": "config.notebook.multiCursor.enabled && notebookCellEditorFocused && activeEditor == 'workbench.editor.notebook'"
	},
	{
		"key": "cmd+d",
		"command": "-composer.toggleChatAsEditor",
		"when": "composerFocused && !editorTextFocus"
	},
	{
		"key": "cmd+l cmd+o",
		"command": "-extension.liveServer.goOnline",
		"when": "editorTextFocus"
	},
	{
		"key": "cmd+l cmd+c",
		"command": "-extension.liveServer.goOffline",
		"when": "editorTextFocus"
	},
	{
		"key": "cmd+l",
		"command": "aichat.newchataction",
		"when": "activeEditor != 'workbench.editor.browserEditor'"
	},
	{
		"key": "cmd+l",
		"command": "-aichat.newchataction",
		"when": "activeEditor != 'workbench.editor.browserEditor'"
	},
	{
		"key": "alt+cmd+s",
		"command": "workbench.action.toggleUnifiedSidebarFromKeyboard",
		"when": "!isAuxiliaryWindowFocusedContext"
	},
	{
		"key": "alt+cmd+s",
		"command": "workbench.action.toggleUnifiedSidebarFromKeyboard",
		"when": "!isAuxiliaryWindowFocusedContext"
	},
	{
		"key": "cmd+d",
		"command": "-glass.splitTileHorizontalFromKeyboard",
		"when": "glassNoModalOpen && isGlassEmptyWorkspace && !editorTextFocus && !glassEditorPanelVisible && !terminalFocusInAny || glassNoModalOpen && isGlassEmptyWorkspace && !editorTextFocus && !terminalFocusInAny && glassActiveTabKind != 'browser'"
	},
	{
		"key": "shift+cmd+d",
		"command": "-glass.splitTileVerticalFromKeyboard",
		"when": "glassNoModalOpen && isGlassEmptyWorkspace && !editorTextFocus && !glassEditorPanelVisible && !terminalFocusInAny || glassNoModalOpen && isGlassEmptyWorkspace && !editorTextFocus && !terminalFocusInAny && glassActiveTabKind != 'browser'"
	}
