// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "autosave": "on_focus_change",
  "git": {
    "enable_diff": true,
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "__CONTEXT7_API_KEY__",
      },
    },
  },
  "diff_view_style": "unified",
  "bottom_dock_layout": "contained",
  "tabs": {
    "file_icons": false,
    "git_status": true,
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": true,
    "show": true,
  },
  "title_bar": {
    "show_menus": false,
    "show_user_picture": false,
    "show_user_menu": true,
    "show_sign_in": true,
    "show_branch_status_icon": false,
  },
  "ui_font_family": ".ZedSans",
  "icon_theme": {
    "mode": "light",
    "light": "Zed (Default)",
    "dark": "Colored Zed Icons Theme Light",
  },
  "agent_servers": {
    "cursor": {
      "default_config_options": {
        "effort": "medium",
        "model": "claude-opus-4-8",
        "mode": "agent",
      },
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
    "codex-acp": {
      "default_config_options": {
        "model": "gpt-5.5",
        "reasoning_effort": "high",
        "mode": "agent-full-access",
      },
      "type": "registry",
    },
    "claude-acp": {
      "default_config_options": {
        "mode": "bypassPermissions",
        "effort": "high",
      },
      "type": "registry",
    },
  },
  "project_panel": {
    "button": true,
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "agent": {
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "gpt-5.5",
      "enable_thinking": false,
    },
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": true,
      "effort": "high",
    },
    "show_turn_stats": true,
    "expand_terminal_card": false,
    "expand_edit_card": false,
    "sandbox_permissions": {
      "allow_unsandboxed": true,
    },
    "tool_permissions": {
      "default": "allow",
      "tools": {},
    },
    "play_sound_when_agent_done": "when_hidden",
    "sidebar_side": "left",
    "dock": "left",
    "favorite_models": [
      {
        "provider": "zed.dev",
        "model": "gpt-5.5",
        "enable_thinking": true,
        "effort": "high",
      },
      {
        "provider": "zed.dev",
        "model": "claude-sonnet-4-6",
        "enable_thinking": true,
        "effort": "high",
      },
    ],
    "model_parameters": [],
  },
  "git_panel": {
    "show_count_badge": true,
    "diff_stats": true,
    "file_icons": false,
    "collapse_untracked_diff": false,
    "sort_by_path": false,
    "status_style": "icon",
    "tree_view": true,
    "dock": "right",
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "buffer_font_family": "Operator Mono Lig",
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "GitHub Dark",
  },
  "terminal": {
    "cursor_shape": "bar",
    "font_family": "Operator Mono Lig",
  },
}
